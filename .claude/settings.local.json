{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(*)",
      "Write(outputs/**)",
      "Edit(outputs/**)",
      "Write(logs/**)",
      "Edit(logs/**)",
      "Bash(python *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(secrets/**)",
      "Bash(rm -rf *)"
    ],
    "defaultMode": "acceptEdits"
  }
}